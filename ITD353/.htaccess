Options -Indexes
RewriteEngine On

# ---------------------------------------------------------------------------
# Block access to sensitive files
# ---------------------------------------------------------------------------
RewriteRule ^(\.env|composer\.json|composer\.lock|\.git)($|/) - [F,L]

# ---------------------------------------------------------------------------
# Forward all requests to the public/ directory (front controller)
# so the app is reachable at  http://localhost/bsu/ITD353/
# without needing  /public/  in the URL.
# ---------------------------------------------------------------------------

# Skip if the request already targets the public/ sub-directory internally
RewriteCond %{REQUEST_URI} ^/bsu/ITD353/public/ [NC]
RewriteRule ^ - [L]

# Forward to public/, preserving path and query string
RewriteRule ^(.*)$ public/$1 [L,QSA]
